build/
**/generated-spring-modulith/
*.class
*.jar
!**/.mvn/wrapper/maven-wrapper.jar
*.log
hs_err_pid*

# ---- Compliance document vault (filesystem FileStorage adapter, DL-0015) ----
backend/var/

# ---- Node / Angular ----
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/coverage/
npm-debug.log*
yarn-error.log*

# ---- Playwright E2E (SPEC-0028): reports/traces/results and downloaded browser binaries — never
