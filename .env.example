# Copy to .env and adjust as needed. Used by docker-compose.yml.
# Database
DB_NAME=acme_erp
DB_USERNAME=acme
DB_PASSWORD=acme
DB_PORT=5432

# Application
APP_PORT=8080
# Observability — structured logs in the container (SPEC-0027/DL-0096): ecs | logstash | gelf
LOGGING_STRUCTURED_FORMAT_CONSOLE=ecs

# Identity / dev IdP (SPEC-0024 Phase 13 / DL-0103/0104). The backend validates the dev Keycloak
# realm's JWTs by JWKS. Keep the issuer URL aligned with KEYCLOAK_PORT (browser and backend use the
# same URL so the token `iss` matches). The admin/admin and seed-user (dev12345) credentials are DEV
# ONLY — never production.
KEYCLOAK_PORT=8088
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
OIDC_ISSUER_URI=http://localhost:8088/realms/acme

# Observability stack (SPEC-0027 / Phase 11)
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
