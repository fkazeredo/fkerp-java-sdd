# Copy to .env and adjust as needed. Used by docker-compose.yml.
# Database
DB_NAME=acme_erp
DB_USERNAME=acme
DB_PASSWORD=acme
DB_PORT=5432

# Application
APP_PORT=8080
# Observability — structured logs in the container (SPEC-0027/DL-0096): ecs | logstash | gelf
LOGGING_STRUCTURED_FORMAT_CONSOLE=ecs

# Identity / self-hosted OIDC (SPEC-0024 Phase 17 / ADR-0018 / DL-0110/0114). The OIDC IdP is now
# EMBEDDED in the app (Spring Authorization Server) — there is NO Keycloak anymore. OIDC_ISSUER_URI is
# the PUBLIC base URL the browser uses to reach the app (and the token `iss`); it must match the
# resource-server issuer-uri. The dev seed users (dev + one per role, password dev12345) live in the
# local store (V32) and are seeded only in the dev/e2e profiles — DEV ONLY, never production.
OIDC_ISSUER_URI=http://localhost:8080

# Observability stack (SPEC-0027 / Phase 11)
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
