{
  "realm": "acme",
  "enabled": true,
  "displayName": "Acme Travel ERP",
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "ROLE_DIRECTOR", "description": "Diretor — emite diretivas comerciais e governa parâmetros" },
      { "name": "ROLE_FINANCE", "description": "Financeiro — emite NF de comissão e fecha período" },
      { "name": "ROLE_OPERATIONS", "description": "Operacional — opera reservas, cotações e pós-venda" },
      { "name": "ROLE_IT", "description": "TI — dispara jobs/crawler e custodia certificado" },
      { "name": "ROLE_POLICY_ADMIN", "description": "Curador de políticas — define regras governadas" },
      { "name": "ROLE_VIEWER", "description": "Leitor — somente consulta" }
    ]
  },
  "clients": [
    {
      "clientId": "acme-erp-web",
      "name": "Acme Travel ERP — Web SPA",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "rootUrl": "http://localhost:4200",
      "baseUrl": "http://localhost:4200",
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost:4201/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost:4201"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/*##http://localhost:4201/*"
      },
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"],
      "optionalClientScopes": ["offline_access"]
    }
  ],
  "users": [
