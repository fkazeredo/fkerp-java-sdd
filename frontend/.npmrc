# PrimeNG 21 declares peer deps on Angular 21 while this project is on Angular 22
# (PrimeNG's major lags Angular's by one — anticipated in DL-0003/DL-0090). The runtime is
# compatible (PrimeNG 21 standalone components run on Angular 22); we pin @angular/cdk to the
# Angular-22 line, not PrimeNG's declared 21. legacy-peer-deps keeps `npm ci` reproducible in CI
# (SPEC-0026 AC1) without --force. Revisit when PrimeNG 22 ships (Phase 14 stack upgrade).
legacy-peer-deps=true
